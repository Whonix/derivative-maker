## AI-Assisted

## PID 1 entrypoint of the dry-run container. Installs systemd-sysv
## (debian:trixie-slim does not ship /sbin/init) and hands over to
## systemd so later 'docker exec' steps can use systemctl (the
## build's apt cache uses the 'approx' systemd unit).

set -o errexit
set -o nounset
set -o pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update -qq
apt-get install --yes --no-install-recommends -- \
   systemd-sysv ca-certificates

## exec is REQUIRED: this script is the container's PID 1; without
## exec, /sbin/init runs as PID > 1 and systemd's boot-check times out.
exec /sbin/init
