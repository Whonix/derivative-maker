## AI-Assisted

## Generate an ephemeral OpenPGP signing key, build an
## openpgp-policy.toml that authorizes that key on top of the
## upstream maintainer keys, re-sign HEAD with it, tag HEAD,
## and recurse into every submodule so each fork-overlaid
## submodule HEAD ends up signed against the same policy.
##
## Auto-dispatch:
##   When invoked top-level, runs the bootstrap (mint key, build
##   policy, amend HEAD, tag, foreach).
##   When invoked from 'git submodule foreach', recognizes the
##   foreach-set $sha1 env var (= the parent's recorded sha for
##   the current submodule), checks whether the working-tree HEAD
##   diverges from that pin, and only amends on divergence.
##   Submodules still at their canonical pin are left alone -
##   their HEAD is signed by an upstream maintainer cert that the
##   bootstrap kept authorized in the seeded policy.
##
## Why this exists:
##   git_sanity_test runs sq-git verification of HEAD as an
##   unconditional cryptographic gate. Three classes of commits
##   fail at it:
##     * Auto-generated PR merge commits at HEAD - no OpenPGP
##       signature at all.
##     * Fork-side branch tips overlaid into submodules - SSH-
##       signed by the contributor's session key, but sq-git only
##       validates OpenPGP, so they look unsigned to it.
##     * Tags created during the build - need a signature from a
##       cert authorized for sign_tag in the policy.
##   Mint an ephemeral OpenPGP key, authorize it as
##   --project-maintainer in a policy file (seeded from the
##   project's openpgp-policy.toml so upstream maintainer keys
##   carry over for unmodified submodules), re-sign HEAD + the
##   new tag + each overlaid submodule HEAD with that key, and
##   point sq_git_policy_file at the policy. Every gate verifies
##   against one consistent policy.
##
## Side effects this script HAS:
##   - Mints a new OpenPGP cert in the caller's sq keystore.
##   - Rewrites HEAD via 'git commit --amend -S' (changes the
##     commit's SHA) - on the parent and on each fork-overlaid
##     submodule.
##   - Adds a signed annotated tag on the parent.
##   - Does NOT write to global git config; signing settings are
##     applied per-invocation via 'git -c key=value' so the
##     caller's persistent ~/.gitconfig is untouched.
##
## The caller is responsible for guarding against running this on
## a developer machine if those side effects aren't wanted.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

repo_root=
repo_root="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." && pwd)"

## DEBFULLNAME / DEBEMAIL: needed by git_options below in BOTH the
## root-mode and submodule-mode branches. signing-key-create runs
## as a separate bash process that sources variables in its own
## subshell, so the defaults it picks for the ephemeral cert never
## reach our shell. Mirror the defaults from help-steps/variables
## (lines ~1168-1172) here; a 'source ./help-steps/variables'
## would be cleaner but trips variables.bsh's own R-010 violations
## under nounset (unprotected ${dist_build_type_long} at line 537,
## etc.). Exported so the foreach recursion below sees them in
## the submodule-mode invocation.
: "${DEBFULLNAME:=derivative distribution auto generated local APT signing key}"
: "${DEBEMAIL:=derivative-distribution@local-signing.key}"
export DEBFULLNAME DEBEMAIL

## git invocation prefix: per-call '-c key=value' pairs that
## configure sq-git-wrapper signing without touching the caller's
## persistent git config. user.signingkey is set to the email;
## sq-git-wrapper detects the '@' and dispatches to 'sq sign
## --signer-email'. Built once and applied to every git command
## that needs to commit / tag.
git_options=(
   -c user.signingkey="${DEBEMAIL}"
   -c gpg.format=openpgp
   -c gpg.openpgp.program="${repo_root}/help-steps/sq-git-wrapper"
   -c commit.gpgsign=true
   -c tag.gpgsign=true
   -c user.email="${DEBEMAIL}"
   -c user.name="${DEBFULLNAME}"
)

## ----- submodule-mode dispatch -------------------------------------
## $sha1 is exported by 'git submodule foreach'; treat its presence
## as the signal that we are a per-submodule invocation. The
## recursion at the end of root mode lands here.
if [ -n "${sha1:-}" ]; then
   if [ "$(git rev-parse HEAD)" = "${sha1}" ]; then
      exit 0
   fi
   git "${git_options[@]}" commit --amend --no-edit -S
   exit 0
fi

## ----- root mode --------------------------------------------------

cd -- "${repo_root}"

## (1) Generate the ephemeral OpenPGP key. signing-key-create is
## idempotent on DEBEMAIL: re-runs are no-ops if a cert with that
## email already exists. Must run as a non-root user;
## signing-key-create's pre-flight rejects root invocations to
## protect a developer's real signing keys.
./help-steps/signing-key-create

## (2) Export every cert in the keystore. On a fresh container the
## keystore has exactly one cert (the ephemeral one signing-key-
## create just minted), so '--all' picks it without us having to
## know the cert's email or fingerprint. Avoids the 'sq cert list
## --format json | jq' parse the trixie sq does not support and
## the awk grep the bash style guide rejects.
ephemeral_cert_pem=
ephemeral_cert_pem="$(mktemp)"
sq cert export --all > "${ephemeral_cert_pem}"

if [ -z "${binary_build_folder_dist:-}" ]; then
   binary_build_folder_dist="${HOME}/derivative-binary"
fi
mkdir --parents -- "${binary_build_folder_dist}"

## (3) Build the policy file at a predictable path so callers can
## compute the location without grepping this script's stdout.
##
## Seed from the project's existing openpgp-policy.toml so the
## upstream maintainer keys remain authorized for any submodule
## HEAD still at its canonical SHA pin. 'sq-git policy authorize'
## below adds our ephemeral key on top, without removing them.
ephemeral_policy="${binary_build_folder_dist}/openpgp-policy.toml"
project_policy="${PWD}/openpgp-policy.toml"
[ -r "${project_policy}" ] \
   || { printf '%s\n' "${BASH_SOURCE[0]}: missing project policy: ${project_policy}" >&2; exit 1; }
cp -- "${project_policy}" "${ephemeral_policy}"

## (4) Authorize the cert. NAME is the policy-file label; use
## DEBFULLNAME so it matches what the cert userid will resolve to.
## --project-maintainer grants the full set (sign_commit, sign_tag,
## sign_archive, add_user, retire_user, audit) - the build needs
## sign_commit and sign_tag at minimum.
sq-git policy authorize \
   --policy-file "${ephemeral_policy}" \
   --project-maintainer \
   "${DEBFULLNAME}" \
   "${ephemeral_cert_pem}"
rm -f -- "${ephemeral_cert_pem}"
printf '%s\n' "${BASH_SOURCE[0]}: wrote policy to ${ephemeral_policy}"

## (5) Re-sign HEAD. --amend --no-edit rewrites the tip without
## changing its content; -S forces a signature pass under the
## inline gpg config from git_options.
git "${git_options[@]}" commit --amend --no-edit -S

## (6) Tag HEAD. Some build steps inspect the latest tag; having
## one present (and signed) is more realistic than --allow-untagged.
## Tag name is 'commit_<full-sha>': prefixed to avoid colliding
## with any branch / tag / ref of the same shape, deterministic
## from HEAD, no environment-variable plumbing.
commit_full_sha=
commit_full_sha="$(git rev-parse HEAD)"
ephemeral_tag="commit_${commit_full_sha}"
git "${git_options[@]}" tag -a -s -m 'Signed by sign-and-tag' "${ephemeral_tag}"
printf '%s\n' "${BASH_SOURCE[0]}: tagged HEAD as ${ephemeral_tag}"

## (7) Recurse into submodules. Each foreach call exports $sha1,
## landing the called script in the submodule-mode branch at the
## top of this file. Single quotes intentional; '$toplevel' is
## expanded by foreach's child shell, not this one.
# shellcheck disable=SC2016
git submodule foreach --recursive '"$toplevel/help-steps/sign-and-tag"'
