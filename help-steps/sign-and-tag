## AI-Assisted

## Sign+tag HEAD for the parent repo and every submodule via the
## sign-tag-head leaf, using the persistent OpenPGP policy file
## written by help-steps/signing-key-create. The caller is
## responsible for guarding against running this on a developer
## machine.
##
## After signing-key-create:
##   ${openpgp_policy_file_user} = ~/buildconfig.d/openpgp-policy.toml
##                                 (project_policy + local maintainer
##                                  cert authorized)
## OR (admin pre-provisioned, no per-user step):
##   ${openpgp_policy_file_system} = /etc/buildconfig.d/openpgp-policy.toml
##
## openpgp_policy_resolve picks the user override first, then the
## system file. If neither exists this script bails out: the operator
## must run signing-key-create.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

repo_root="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." && pwd)"

export dist_build_source_run=true
export dist_build_one_parsed=true
# shellcheck source=help-steps/pre
source "${repo_root}/help-steps/pre"
# shellcheck source=help-steps/variables
source "${repo_root}/help-steps/variables"

cd -- "${repo_root}"

## Refuse to run for redistributable builds. Two reasons:
##
##   1. Redistributable builds (dist_build_redistributable=true,
##      set by help-steps/dm-build-official) rely on offline-signed
##      upstream tags exclusively. Re-tagging or re-signing locally
##      defeats the offline-key trust root and produces images
##      whose tag history doesn't match what shipped upstream.
##   2. The maintainer's redistributable-build signing key lives
##      OFFLINE by design; this script's openpgp_policy_setup ->
##      sq cert export path needs the local sq cert store to
##      contain the cert, which it deliberately doesn't on a
##      redistributable-build host.
##
## sign-and-tag's only legitimate caller is ci/dry-run.d/200_sign-and-tag
## (the CI dry-run pipeline). Personal builds may also invoke it.
## Production / redistributable builds must not.
if [ "${dist_build_redistributable:-}" = 'true' ]; then
   printf '%s\n' \
      "${BASH_SOURCE[0]}: refusing to run for redistributable build" \
      "  (dist_build_redistributable=true)" \
      "Redistributable builds use offline-signed upstream tags" \
      "exclusively; the local-cert authorize + per-build sign+tag" \
      "flow this script implements is for personal / CI dry-run" \
      "builds only. If this fired during a real CI dry-run, check" \
      "whether dist_build_redistributable was inherited from the" \
      "outer build environment via env or buildconfig.d/*.conf." >&2
   exit 1
fi

## Idempotent setup. Re-running picks up upstream maintainer-key
## rotation if project_policy changed since last invocation. The
## script is a no-op on the cert side once a key exists.
./help-steps/signing-key-create

policy_file="$(openpgp_policy_resolve)"
if [ -z "${policy_file}" ]; then
   printf '%s\n' \
      "${BASH_SOURCE[0]}: no OpenPGP policy file at" \
      "  ${openpgp_policy_file_user}" \
      "  or ${openpgp_policy_file_system}" \
      "Run help-steps/signing-key-create first to write the user-side" \
      "policy, or pre-provision the system path." >&2
   exit 1
fi
printf '%s\n' "${BASH_SOURCE[0]}: using policy ${policy_file}"

export sq_git_policy_file="${policy_file}"

./help-steps/sign-tag-head 'main repo'

## '$toplevel' and '$displaypath' are foreach's env, expanded by
## its child shell. displaypath is the submodule's relative path -
## passed explicitly to sign-tag-head as the context label so the
## per-submodule output identifies which submodule the line is
## about. Auto-detection from inside sign-tag-head was removed in
## favour of this explicit argument.
# shellcheck disable=SC2016
git submodule foreach --recursive '"$toplevel/help-steps/sign-tag-head" "$displaypath"'
