## AI-Assisted

## Sign+tag HEAD for the parent repo and every submodule via the
## sign-tag-head leaf.
##
## Preconditions:
##   - signing key for ${DEBEMAIL} exists in the sq keystore
##   - a maintainer-authorized policy file exists at one of
##     ${openpgp_policy_file_user} / ${openpgp_policy_file_system}
##
## help-steps/signing-key-create produces both idempotently and is
## invoked by build-steps.d/1200_prepare-build-machine (real builds)
## and ci/dry-run.d/150_signing-key-create (CI dry-run).

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

repo_root="$(cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.." && pwd)"

export dist_build_source_run=true
export dist_build_one_parsed=true
# shellcheck source=help-steps/pre
source "${repo_root}/help-steps/pre"
# shellcheck source=help-steps/variables
source "${repo_root}/help-steps/variables"

cd -- "${repo_root}"

## Redistributable builds rely on offline-signed upstream tags;
## re-tagging or re-signing locally defeats the offline-key trust
## root. Legitimate callers: ci/dry-run.d/200_sign-and-tag and
## personal builds.
if [ "${dist_build_redistributable:-}" = 'true' ]; then
   printf '%s\n' \
      "${BASH_SOURCE[0]}: refusing to run for redistributable build" \
      "  (dist_build_redistributable=true)" \
      "Redistributable builds use offline-signed upstream tags" \
      "exclusively. If this fired during a real CI dry-run, check" \
      "whether dist_build_redistributable was inherited from the" \
      "outer build environment via env or buildconfig.d/*.conf." >&2
   exit 1
fi

if [ -z "${openpgp_policy_file_resolved}" ]; then
   printf '%s\n' \
      "${BASH_SOURCE[0]}: no maintainer-authorized OpenPGP policy at" \
      "  ${openpgp_policy_file_user}" \
      "  or ${openpgp_policy_file_system}" \
      "Run help-steps/signing-key-create to create the user-side" \
      "policy, or pre-provision either path manually." >&2
   exit 1
fi
printf '%s\n' "${BASH_SOURCE[0]}: using policy ${sq_git_policy_file}"

## Fail fast on a misconfigured keystore (e.g. split-gpg-2
## unreachable) before sign-tag-head's destructive 'commit --amend -S'
## walks every submodule.
./help-steps/signing-key-test

./help-steps/sign-tag-head 'main repo'

## '$toplevel' and '$displaypath' are foreach's env, expanded by
## its child shell. $displaypath is the submodule's relative path,
## passed explicitly to sign-tag-head as the context label so the
## per-submodule output identifies which submodule the line is
## about.
# shellcheck disable=SC2016
git submodule foreach --recursive '"$toplevel/help-steps/sign-tag-head" "$displaypath"'
