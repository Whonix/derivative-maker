set -x
set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

true "INFO: Currently running script: ${BASH_SOURCE[0]} $*"

MYDIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

cd "$MYDIR"
cd ..
cd help-steps

dist_build_source_run="true"

source pre
source variables

main() {
   sanity_tests "$@"
   gpg_key_create "$@"
   gpg_key_debugging "$@"
   signify_key_create "$@"
   openpgp_policy_setup "$@"
   true "INFO: END of ${FUNCNAME[0]}"
}

sanity_tests() {
   command -v sq >/dev/null
   command -v sq-git >/dev/null
   command -v sqop >/dev/null
   command -v signify-openbsd >/dev/null
}

gpg_key_create() {
   true "DEBEMAIL: $DEBEMAIL"
   ## Debugging.
   pwd

   if sq cert list --cert-email "$DEBEMAIL" &>/dev/null ; then
      true "INFO: OpenPGP key with uid DEBEMAIL $DEBEMAIL already exists. Skipping OpenPGP key creation, ok."
      return 0
   fi

   true "INFO: OpenPGP key with uid DEBEMAIL $DEBEMAIL does not exist yet. Generating OpenPGP key..."

   ## Not idempotent. (Would generate different key.)
   ##
   ## Useful for CI to test 'dm-prepare-release' image signing.
   ##
   ## 'sqop': Not stateful.
   ## * In theory, sqop would be more suitable. 'sqop' does not use 'gpg-agent'.
   ## * In practice, redistributable builds are created using Qubes 'split-gpt-2',
   ##   which is using 'gpg-agent'. Hence, 'sq' is being used.
   ## 'sqop generate-key | tee -- private-key-path >/dev/null'
   ##
   ## 'sq': Stateful.
   ## '--without-password' / '--expiration never':
   ##  * Not useful on CI.
   ## -* Users who did not study 'sq' have no benefit.
   ## -* Users that studied 'sq' manually generate the key.
   ##
   ## TODO: Debian forky: Drop or upgrade '--profile rfc9580' depending on availability.
   sq key generate --profile rfc9580 --own-key --email "$DEBEMAIL" --without-password --expiration never

   true "INFO: END of ${FUNCNAME[0]}"
}

gpg_key_debugging() {
   true "INFO: show OpenPGP key fingerprint for uid DEBEMAIL"
   ## Just output list of secret keys in that very folder in case that ever breaks and someone ever sends
   ## a build log, this will help with debugging.
   ## Idempotent.
   sq cert list --cert-email "$DEBEMAIL"
   sq cert lint --cert-email "$DEBEMAIL"
}

## Signify keys are used by 'dm-prepare-release' in package 'developer-meta-files'.
signify_key_create() {
   mkdir --parents -- "$signify_folder"
   chmod --recursive -- og-rwx "$signify_folder"

   if test -f "$signify_private_key" ; then
      true "INFO: signify_private_key $signify_private_key already exists. Skipping signify signing key generation, ok."
      test -r "$signify_private_key"
      return 0
   fi

   true "INFO: signify_private_key $signify_private_key does not exist yet. Generating signify signing key..."
   pushd -- "$signify_folder" >/dev/null
   ## Not idempotent. (Would generate different key.)
   signify-openbsd -n -G -p "$signify_public_key" -s "$signify_private_key" -c "derivative-maker"
   popd >/dev/null

   true "INFO: END of ${FUNCNAME[0]}"
}

## OpenPGP policy persistent setup. Replaces the per-build ephemeral-
## policy churn that lived in help-steps/sign-and-tag. After this
## function:
##
##   ${openpgp_policy_file_user} = a copy of ${source_code_folder_dist}/
##                                 openpgp-policy.toml with the local
##                                 maintainer's cert authorized as
##                                 --project-maintainer alongside the
##                                 upstream maintainer keys.
##   ${openpgp_cert_file_user}   = the local maintainer's public cert
##                                 (output of `sq cert export --all`).
##
## Idempotent at the result level: re-running this script after
## upstream rotates a maintainer key in the shipped openpgp-policy.toml
## refreshes the user-side copy. Operator runs signing-key-create
## once per machine, then again after any pull that touches the
## shipped policy.
##
## Path locations live in help-steps/variables (openpgp_policy_file_user,
## openpgp_cert_file_user). User override only - the /etc/buildconfig.d/
## system path is read by openpgp_policy_resolve but never written here.
openpgp_policy_setup() {
   local project_policy="${source_code_folder_dist}/openpgp-policy.toml"
   local user_policy_dir
   user_policy_dir="$(dirname -- "${openpgp_policy_file_user}")"

   if [ ! -r "${project_policy}" ]; then
      true "INFO: ${project_policy} not present; skipping openpgp-policy setup"
      return 0
   fi

   ## 0700 on the parent dir keeps other local users out of the
   ## cert + policy file. The cert is public so the dir mode is
   ## defense-in-depth; the policy file is also non-secret. mkdir
   ## --parents is idempotent.
   mkdir --parents -- "${user_policy_dir}"
   chmod -- 0700 "${user_policy_dir}"

   ## Idempotent: each file is created only if absent. Pre-existing
   ## files are PRESERVED, not overwritten. This supports two use
   ## cases:
   ##
   ##   1. Provisioning. An admin / setup script can drop pre-built
   ##      versions of openpgp_cert_file_user and openpgp_policy_file_user
   ##      ahead of time; signing-key-create will leave them alone.
   ##   2. Re-running this script. The existing files are presumed
   ##      correct (authored either by a previous run or by an
   ##      operator). signing-key-create stays a no-op on the second
   ##      and subsequent runs.
   ##
   ## To force a refresh (e.g. after upstream rotates a maintainer
   ## key in project_policy, or after rotating the local cert),
   ## delete the file(s) and re-run. Same explicit-action pattern
   ## as gpg_key_create's "skip if cert exists for ${DEBEMAIL}".

   ## Cert export. Email-scoped (--cert-email "${DEBEMAIL}") rather
   ## than --all so only the maintainer's cert is authorized in the
   ## policy. Critical for redistributable builds in Qubes split-gpg-2:
   ## the build VM's local cert store may carry test certs, rotated
   ## old certs, or certs from unrelated projects; --all would
   ## indiscriminately authorize every one of them as a
   ## project-maintainer.
   ## Email selection is split-gpg-2-safe: it consults the build
   ## VM's local public-cert store only, no private-key access (the
   ## private key lives in the dedicated split-gpg-2 VM by design).
   ## File mode 0600 is defense-in-depth - 'sq cert export' emits
   ## public certificates ('sq key export' would emit secret).
   if [ -r "${openpgp_cert_file_user}" ]; then
      true "INFO: ${openpgp_cert_file_user} already exists; preserving (provisioned or carried over). Delete to force re-export."
   else
      true "INFO: exporting local maintainer cert (DEBEMAIL=${DEBEMAIL}) -> ${openpgp_cert_file_user}"
      ## Prefer sponge (moreutils) when available: buffers stdin in
      ## memory then atomically renames into place. Crash-safe -
      ## an interrupted write leaves the destination file
      ## untouched, preserving the idempotence guarantee above
      ## (next run sees no file, redoes the export).
      ##
      ## tee fallback is non-atomic (writes byte-by-byte) but
      ## still beats bare '>' for this script's '-x' xtrace
      ## visibility: the target path shows up in the trace where
      ## a redirection target would not.
      ##
      ## Both forms accept '--' end-of-options. R-062.
      if command -v sponge >/dev/null; then
         sq cert export --cert-email "${DEBEMAIL}" \
            | sponge -- "${openpgp_cert_file_user}"
      else
         sq cert export --cert-email "${DEBEMAIL}" \
            | tee -- "${openpgp_cert_file_user}" >/dev/null
      fi
      chmod -- 0600 "${openpgp_cert_file_user}"
   fi

   ## Policy file. The presence of a pre-existing file means it has
   ## been authored already (provisioned admin policy, or previous
   ## run). Don't run sq-git policy authorize on it - the existing
   ## file's authorized-maintainer list is presumed correct. After
   ## this, sq-git verification with
   ## --policy-file=${openpgp_policy_file_user} accepts the
   ## upstream maintainer keys (preserved from project_policy or
   ## from whatever the provisioning step put there) and the local
   ## maintainer.
   if [ -r "${openpgp_policy_file_user}" ]; then
      true "INFO: ${openpgp_policy_file_user} already exists; preserving (provisioned or carried over). Delete to force re-derive from ${project_policy}."
      true "INFO: END of ${FUNCNAME[0]}"
      return 0
   fi

   true "INFO: copying shipped project policy ${project_policy} -> ${openpgp_policy_file_user}"
   cp -- "${project_policy}" "${openpgp_policy_file_user}"
   chmod -- 0600 "${openpgp_policy_file_user}"

   true "INFO: authorizing local maintainer cert as project-maintainer in ${openpgp_policy_file_user}"
   true "INFO:   --policy-file        ${openpgp_policy_file_user}"
   true "INFO:   --project-maintainer ${DEBFULLNAME}"
   true "INFO:   cert                 ${openpgp_cert_file_user}"
   sq-git policy authorize \
      --policy-file "${openpgp_policy_file_user}" \
      --project-maintainer \
      "${DEBFULLNAME}" \
      "${openpgp_cert_file_user}"

   true "INFO: END of ${FUNCNAME[0]}"
}

main "$@"
