## AI-Assisted

## Ensure a qemu-user binfmt handler carries the 'C' (credentials) flag so that
## setuid binaries (notably 'sudo') gain root inside an emulated foreign-arch
## chroot -- for example the amd64 VirtualBox chroot built on an arm64 host.
## Without the flag the kernel derives credentials from the unprivileged qemu
## interpreter instead of the setuid target, so 'sudo' fails with a misleading
## 'sudo: effective uid is not 0 ... nosuid' error.
##
## The handler is updated THROUGH 'update-binfmts', never by a raw write to
## /proc/sys/fs/binfmt_misc/register: mmdebstrap, which bootstraps the foreign
## chroot, gates on 'update-binfmts --display <name>' succeeding, so a raw
## /proc write desynchronises update-binfmts' database and makes mmdebstrap
## report 'qemu-<arch> not in database ... can neither be executed natively nor
## via qemu user emulation'.
##
## update-binfmts cannot toggle credentials in place, so the handler is removed
## and re-installed with --credential yes, preserving its package, interpreter,
## magic, mask and offset (read back from 'update-binfmts --display') plus the
## P (preserve-argv0) and F (fix-binary, required inside a chroot) flags.
##
## Standalone and dependency-minimal (like help-steps/retry-run): it is executed
## as root, not sourced, so it cannot use the build's 'log'/'error' helpers and
## reports via printf to stderr.
## Must run as root. Idempotent: a no-op when the 'C' flag is already present.
##
## Usage: binfmt-credential-setup <qemu-binfmt-name>   (e.g. qemu-x86_64)

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

binfmt_name="${1:-}"
if [ -z "${binfmt_name}" ]; then
   printf '%s\n' "${BASH_SOURCE[0]}: usage: binfmt-credential-setup <qemu-binfmt-name>" >&2
   exit 64
fi

binfmt_handler="/proc/sys/fs/binfmt_misc/${binfmt_name}"

## Diagnostics: current registration (aids debugging on an unfamiliar runner).
printf '%s\n' "INFO: binfmt registration for '${binfmt_name}':" >&2
update-binfmts --display "${binfmt_name}" 1>&2 || true

## Idempotent: nothing to do when the credentials flag is already set.
if [ -e "${binfmt_handler}" ] && grep --quiet -- '^flags:.*C' "${binfmt_handler}"; then
   printf '%s\n' "INFO: '${binfmt_name}' already carries the 'C' (credentials) flag; nothing to do." >&2
   exit 0
fi

binfmt_display="$(update-binfmts --display "${binfmt_name}" 2>/dev/null || true)"
if [ -z "${binfmt_display}" ]; then
   printf '%s\n' "${BASH_SOURCE[0]}: '${binfmt_name}' is not known to update-binfmts; cannot add the credentials flag." >&2
   exit 1
fi

## 'update-binfmts --display' prints '     <key> = <value>' lines. awk is not
## '--'-safe, and the input arrives on stdin, so no '--' is used.
binfmt_package="$(printf '%s\n' "${binfmt_display}" | awk -F ' = ' '/^ *package =/ { print $2; exit }')"
binfmt_interpreter="$(printf '%s\n' "${binfmt_display}" | awk -F ' = ' '/^ *interpreter =/ { print $2; exit }')"
binfmt_offset="$(printf '%s\n' "${binfmt_display}" | awk -F ' = ' '/^ *offset =/ { print $2; exit }')"
binfmt_magic="$(printf '%s\n' "${binfmt_display}" | awk -F ' = ' '/^ *magic =/ { print $2; exit }' | tr -d ' \t')"
binfmt_mask="$(printf '%s\n' "${binfmt_display}" | awk -F ' = ' '/^ *mask =/ { print $2; exit }' | tr -d ' \t')"

[ -n "${binfmt_package}" ] || binfmt_package="qemu-user-binfmt"
[ -n "${binfmt_offset}" ] || binfmt_offset="0"

## update-binfmts --magic/--mask take '\xNN'-escaped byte strings, which is
## exactly the form 'update-binfmts --display' already prints (e.g.
## 'magic = \x7f\x45\x4c\x46'). Reuse the displayed values verbatim; do NOT
## re-escape them (that would double the escapes into '\x\x\x7f...' and the
## reinstall would fail).
if [ -z "${binfmt_interpreter}" ] || [ -z "${binfmt_magic}" ] || [ -z "${binfmt_mask}" ]; then
   printf '%s\n' "${BASH_SOURCE[0]}: could not parse the '${binfmt_name}' registration; refusing to modify it." >&2
   exit 1
fi

printf '%s\n' "INFO: re-installing '${binfmt_name}' via update-binfmts with the credentials flag." >&2
## '|| true' on remove/install so update-binfmts' own diagnostics still reach
## the log while the verification below stays the authoritative pass/fail.
update-binfmts --package "${binfmt_package}" --remove "${binfmt_name}" "${binfmt_interpreter}" || true
update-binfmts \
   --package "${binfmt_package}" \
   --install "${binfmt_name}" "${binfmt_interpreter}" \
   --magic "${binfmt_magic}" \
   --mask "${binfmt_mask}" \
   --offset "${binfmt_offset}" \
   --credential yes \
   --preserve yes \
   --fix-binary yes \
   || true

if [ ! -e "${binfmt_handler}" ] || ! grep --quiet -- '^flags:.*C' "${binfmt_handler}"; then
   printf '%s\n' "${BASH_SOURCE[0]}: failed to add the 'C' (credentials) flag to '${binfmt_name}'." >&2
   update-binfmts --display "${binfmt_name}" 1>&2 || true
   exit 1
fi

printf '%s\n' "INFO: '${binfmt_name}' now carries the 'C' (credentials) flag." >&2
