## AI-Assisted

## Phase 300: walk every submodule via 'git submodule foreach' and
## re-sign each fork-overlaid HEAD with the parent's CI signing
## key (set up as --global git config in phase 200).
##
## Same pattern as help-steps/git_sanity_test's mode_submodules:
## 'foreach --recursive' calls a per-submodule helper. The helper
## (help-steps/sign-submodule-head) reads $sha1 (the parent's
## index pin) that foreach exports, compares to the working-tree
## HEAD, and amends only when they differ - submodules still at
## their canonical pin are left alone (their HEAD is already
## signed by an upstream maintainer cert that sign-and-tag kept
## authorized in the seeded policy).
##
## Runs as 'builder' so the amend uses the same git identity and
## signing config sign-and-tag wrote in phase 200.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/../.."

## Single quotes intentional: '$toplevel' is exported by 'git submodule
## foreach' for its child shell to expand per-submodule. Expanding it
## now would substitute the parent shell's (empty) value.
# shellcheck disable=SC2016
exec ./help-steps/run-as-user --chown /work -- builder \
   git submodule foreach --recursive '"$toplevel/help-steps/sign-submodule-head"'
