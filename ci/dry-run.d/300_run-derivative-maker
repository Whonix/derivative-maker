## AI-Assisted

## Drop privileges and run derivative-maker --dry-run. The
## --policy-file value is computed from the target user's home
## (via getent so there's no '/home/<user>/' literal); --policy-file
## is consumed by parse-cmd which exports sq_git_policy_file for
## git_sanity_test.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

target_user=builder

cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/../.."

target_home="$(getent passwd "${target_user}" | cut -d: -f6)"

timeout 1200 \
   ./help-steps/run-as-user --chown "$PWD" -- \
      "${target_user}" \
      ./derivative-maker \
         --policy-file "${target_home}/derivative-binary/openpgp-policy.toml" \
         --dry-run true \
         --unsupported-os true \
         --allow-uncommitted true \
         --allow-untagged true \
         --flavor source \
         --target source
