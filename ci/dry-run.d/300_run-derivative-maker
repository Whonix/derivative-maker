## Phase 300: run derivative-maker --dry-run as the unprivileged
## target user.
##
## Compute the path to the policy file from the target user's home
## dir via getent (matches binary_build_folder_dist's default in
## help-steps/variables when run as that user). Avoids a literal
## '/home/<user>/' string. Single ': '-delimited field extraction
## is standard Unix, not awk.
##
## --policy-file is consumed by parse-cmd, which exports
## sq_git_policy_file for git_sanity_test - cleaner than passing
## across the run-as-user sudo via 'env VAR=val'.
##
## sq_git_trust_root is NOT set: help-steps/variables defaults it
## to "HEAD" for non-redistributable builds.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

target_user=builder

cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/../.."

target_home="$(getent passwd "${target_user}" | cut -d: -f6)"

timeout 1200 \
   ./help-steps/run-as-user --chown "$PWD" -- \
      "${target_user}" \
      ./derivative-maker \
         --policy-file "${target_home}/derivative-binary/openpgp-policy.toml" \
         --dry-run true \
         --unsupported-os true \
         --allow-uncommitted true \
         --allow-untagged true \
         --flavor source \
         --target source
