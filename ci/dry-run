## AI-Assisted

## Walks ci/dry-run.d/* via run-parts. Mirrors derivative-maker's
## own build-steps.d/ dispatcher.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

if [ "${CI:-}" != "true" ]; then
   printf '%s: refusing to run outside CI (CI != "true")\n' "${BASH_SOURCE[0]}" >&2
   exit 1
fi

cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.."

run-parts --exit-on-error --verbose -- ./ci/dry-run.d
