## AI-Assisted

## After 'git submodule update --init', walk every submodule and
## switch to the same-named branch on its origin remote when one
## exists; submodules without a matching branch keep the SHA pin
## from the parent's index. Per-submodule action lives in
## ci/checkout-fork-branch.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace

if [ "$#" -ne 1 ]; then
   printf '%s\n' "usage: ${BASH_SOURCE[0]} <branch>" >&2
   exit 64
fi

branch="$1"

case "${branch}" in
   *[!a-zA-Z0-9._/-]*|"")
      printf '%s\n' "${BASH_SOURCE[0]}: refusing suspicious branch name: '${branch}'" >&2
      exit 64
      ;;
esac

cd -- "$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")/.."

## '$toplevel' is foreach's env, expanded by its child shell.
# shellcheck disable=SC2016
FORK_BRANCH="${branch}" \
   git submodule foreach --recursive '"$toplevel/ci/checkout-fork-branch"'
